<?xml version="1.0" encoding="utf-8"?>
<!--
  FactoryOS Enterprise — NuGet configuration.
  A single, explicit package source with source mapping, so every restore is
  reproducible and no package can be silently pulled from an unexpected feed.
-->
<configuration>
  <packageSources>
    <!-- Clear any inherited sources so only the ones declared here are used. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <config>
    <add key="dependencyVersion" value="Highest" />
  </config>
</configuration>
