# The monitoring engine's stateless collaborators (aggregator, sampler, executor, search service) are
# registered, injectable services per the engine contract; that some hold no fields does not mean their public
# API should be static, so CA1822 "mark members static" does not apply. CA1859 "use concrete types for improved
# performance" does not apply to the store and repository seams that deliberately return interface abstractions.
[*.cs]
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.CA1859.severity = none
