# FactoryOS web shell — sample dev configuration.
# The shell is same-origin: in production it is served behind the gateway, so no base URL is needed.
# In dev, Vite proxies the gateway's discovery + module routes (see vite.config.ts).

# Where `vite dev` proxies /shell, /system, /modules, /store, /m to. Defaults to http://localhost:8080.
FACTORYOS_GATEWAY=http://localhost:8080

# The tenant is chosen per-request via ?tenant=<key> in the URL (dev default: "acme").
# Example: http://localhost:5173/?tenant=acme
